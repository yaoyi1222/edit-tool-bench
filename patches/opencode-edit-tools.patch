+import { afterEach, describe, expect } from "bun:test"
+import path from "path"
+import { createHash } from "crypto"
+import { Cause, Effect, Exit, Layer } from "effect"
+import { Agent } from "@/agent/agent"
+import { EventV2Bridge } from "@/event-v2-bridge"
+import { Format } from "@/format"
+import { LSP } from "@/lsp/lsp"
+import { MessageID, SessionID } from "@/session/schema"
+import { ApplyUnifiedPatchTool } from "@/tool/apply_unified_patch"
+import { EditTransactionTool } from "@/tool/edit_transaction"
+import { InsertByAnchorTool } from "@/tool/insert_by_anchor"
+import { ReplaceByAnchorTool } from "@/tool/replace_by_anchor"
+import { ReplaceExactTool } from "@/tool/replace_exact"
+import { Truncate } from "@/tool/truncate"
+import * as Tool from "@/tool/tool"
+import { FSUtil } from "@opencode-ai/core/fs-util"
+import { disposeAllInstances, TestInstance } from "../fixture/fixture"
+import { testEffect } from "../lib/effect"
+
+const ctx = {
+  sessionID: SessionID.make("ses_test-edit-toolkit-session"),
+  messageID: MessageID.make("msg_test"),
+  callID: "",
+  agent: "build",
+  abort: AbortSignal.any([]),
+  messages: [],
+  metadata: () => Effect.void,
+  ask: () => Effect.void,
+}
+
+afterEach(async () => {
+  await disposeAllInstances()
+})
+
+const layer = Layer.mergeAll(
+  LSP.defaultLayer,
+  FSUtil.defaultLayer,
+  Format.defaultLayer,
+  EventV2Bridge.defaultLayer,
+  Truncate.defaultLayer,
+  Agent.defaultLayer,
+)
+
+const it = testEffect(layer)
+
+const put = Effect.fn("EditToolkitTest.put")(function* (file: string, content: string) {
+  const fs = yield* FSUtil.Service
+  yield* fs.writeWithDirs(file, content)
+})
+
+const load = Effect.fn("EditToolkitTest.load")(function* (file: string) {
+  const fs = yield* FSUtil.Service
+  return yield* fs.readFileString(file)
+})
+
+const sha256 = (content: string) => createHash("sha256").update(content).digest("hex")
+
+type ToolEffect =
+  | typeof ApplyUnifiedPatchTool
+  | typeof EditTransactionTool
+  | typeof InsertByAnchorTool
+  | typeof ReplaceByAnchorTool
+  | typeof ReplaceExactTool
+
+const init = Effect.fn("EditToolkitTest.init")(function* (info: ToolEffect) {
+  const resolved = yield* info
+  return yield* resolved.init()
+})
+
+const run = Effect.fn("EditToolkitTest.run")(function* (info: ToolEffect, args: Record<string, unknown>) {
+  const tool = yield* init(info)
+  const execute = tool.execute as unknown as (
+    input: Record<string, unknown>,
+    next: Tool.Context,
+  ) => Effect.Effect<Tool.ExecuteResult>
+  return yield* execute(args, ctx)
+})
+
+const fail = Effect.fn("EditToolkitTest.fail")(function* (info: ToolEffect, args: Record<string, unknown>) {
+  const exit = yield* run(info, args).pipe(Effect.exit)
+  if (Exit.isFailure(exit)) {
+    const err = Cause.squash(exit.cause)
+    return err instanceof Error ? err : new Error(String(err))
+  }
+  throw new Error("expected edit toolkit tool to fail")
+})
+
+describe("edit toolkit tools", () => {
+  it.instance("replace_exact replaces one unique exact block and reports benchmark metadata", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "src/auth.ts")
+      yield* put(file, "const user = await findUser(email)\nif (!user) return null\n")
+
+      const result = yield* run(ReplaceExactTool, {
+        file,
+        expected_sha256: sha256("const user = await findUser(email)\nif (!user) return null\n"),
+        old: "if (!user) return null",
+        new: "if (!user) throw new AuthError('User not found')",
+      })
+
+      expect(yield* load(file)).toContain("throw new AuthError")
+      expect(result.metadata.ok).toBe(true)
+      expect(result.metadata.tool).toBe("replace_exact")
+      expect(result.metadata.files_changed).toEqual([file])
+      expect(result.metadata.changed_lines).toBeGreaterThan(0)
+      expect(result.metadata.requires_reread).toBe(true)
+      expect(result.metadata.diff).toContain("-if (!user) return null")
+    }),
+  )
+
+  it.instance("replace_exact rejects ambiguous matches without changing the file", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "dupe.txt")
+      yield* put(file, "foo\nfoo\n")
+
+      const error = yield* fail(ReplaceExactTool, { file, old: "foo", new: "bar" })
+
+      expect(error.message).toContain("AMBIGUOUS_MATCH")
+      expect(yield* load(file)).toBe("foo\nfoo\n")
+    }),
+  )
+
+  it.instance("replace_exact rejects hash mismatches before editing", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "hash.txt")
+      yield* put(file, "current\n")
+
+      const error = yield* fail(ReplaceExactTool, {
+        file,
+        expected_sha256: sha256("stale\n"),
+        old: "current",
+        new: "next",
+      })
+
+      expect(error.message).toContain("HASH_MISMATCH")
+      expect(yield* load(file)).toBe("current\n")
+    }),
+  )
+
+  it.instance("replace_by_anchor replaces the uniquely anchored range", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "anchor.ts")
+      yield* put(file, "before\nfunction login() {\n  return null\n}\nafter\n")
+
+      yield* run(ReplaceByAnchorTool, {
+        file,
+        start_anchor: "function login() {",
+        end_anchor: "}",
+        include_start: true,
+        include_end: true,
+        new: "function login() {\n  return createSession()\n}",
+      })
+
+      expect(yield* load(file)).toBe("before\nfunction login() {\n  return createSession()\n}\nafter\n")
+    }),
+  )
+
+  it.instance("insert_by_anchor inserts text after the unique anchor and supports duplicate guards", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "auth.test.ts")
+      yield* put(file, "describe('login', () => {\n})\n")
+
+      yield* run(InsertByAnchorTool, {
+        file,
+        anchor: "describe('login', () => {",
+        position: "after",
+        content: "\n  it('rejects missing profile', () => {})",
+        must_not_already_contain: "rejects missing profile",
+      })
+
+      expect(yield* load(file)).toBe("describe('login', () => {\n  it('rejects missing profile', () => {})\n})\n")
+    }),
+  )
+
+  it.instance("insert_by_anchor inserts at every occurrence when expected_matches matches the count", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "multi.ts")
+      yield* put(file, "// mark\ncode\n// mark\n")
+
+      yield* run(InsertByAnchorTool, {
+        file,
+        anchor: "// mark",
+        position: "after",
+        content: " inserted",
+        expected_matches: 2,
+      })
+
+      expect(yield* load(file)).toBe("// mark inserted\ncode\n// mark inserted\n")
+    }),
+  )
+
+  it.instance("insert_by_anchor rejects when occurrence count differs from expected_matches", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "multi.ts")
+      yield* put(file, "// mark\ncode\n// mark\n")
+
+      const error = yield* fail(InsertByAnchorTool, {
+        file,
+        anchor: "// mark",
+        position: "after",
+        content: " inserted",
+        expected_matches: 1,
+      })
+
+      expect(error.message).toContain("ANCHOR_NOT_UNIQUE")
+      expect(yield* load(file)).toBe("// mark\ncode\n// mark\n")
+    }),
+  )
+
+  it.instance("replace_by_anchor refuses expected_matches greater than one with a clear error", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "ranges.ts")
+      yield* put(file, "<a>one</a>\n<a>two</a>\n")
+
+      const error = yield* fail(ReplaceByAnchorTool, {
+        file,
+        start_anchor: "<a>",
+        end_anchor: "</a>",
+        expected_matches: 2,
+        new: "<a>x</a>",
+      })
+
+      expect(error.message).toContain("SINGLE_RANGE_ONLY")
+      expect(yield* load(file)).toBe("<a>one</a>\n<a>two</a>\n")
+    }),
+  )
+
+  it.instance("apply_unified_patch applies a standard multi-file unified diff atomically", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "file.txt")
+      yield* put(file, "alpha\nbeta\n")
+
+      const patch = [
+        "--- a/file.txt",
+        "+++ b/file.txt",
+        "@@ -1,2 +1,2 @@",
+        " alpha",
+        "-beta",
+        "+gamma",
+        "--- /dev/null",
+        "+++ b/new.txt",
+        "@@ -0,0 +1 @@",
+        "+created",
+        "",
+      ].join("\n")
+
+      const result = yield* run(ApplyUnifiedPatchTool, {
+        patch,
+        expected_files: {
+          "file.txt": sha256("alpha\nbeta\n"),
+        },
+      })
+
+      expect(yield* load(file)).toBe("alpha\ngamma\n")
+      expect(yield* load(path.join(test.directory, "new.txt"))).toBe("created\n")
+      expect(result.metadata.files_changed.toSorted()).toEqual([
+        path.join(test.directory, "file.txt"),
+        path.join(test.directory, "new.txt"),
+      ].toSorted())
+    }),
+  )
+
+  it.instance("apply_unified_patch does not report fuzz when a patch applies cleanly", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "clean.txt")
+      yield* put(file, "alpha\nbeta\n")
+
+      const result = yield* run(ApplyUnifiedPatchTool, {
+        patch: ["--- a/clean.txt", "+++ b/clean.txt", "@@ -1,2 +1,2 @@", " alpha", "-beta", "+gamma", ""].join("\n"),
+        allow_fuzz: true,
+      })
+
+      expect(yield* load(file)).toBe("alpha\ngamma\n")
+      expect(result.metadata.warnings).not.toContain("fuzzy_applied=true")
+    }),
+  )
+
+  it.instance("apply_unified_patch reports fuzz only when fuzzy matching was actually used", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "fuzzy.txt")
+      yield* put(file, "h1\nh2\nh3\nold_value\nf1\nf2\nf3\n")
+
+      const result = yield* run(ApplyUnifiedPatchTool, {
+        patch: [
+          "--- a/fuzzy.txt",
+          "+++ b/fuzzy.txt",
+          "@@ -1,7 +1,7 @@",
+          " h1",
+          " DRIFTED",
+          " h3",
+          "-old_value",
+          "+new_value",
+          " f1",
+          " f2",
+          " f3",
+          "",
+        ].join("\n"),
+        allow_fuzz: true,
+      })
+
+      expect(yield* load(file)).toContain("new_value")
+      expect(result.metadata.warnings).toContain("fuzzy_applied=true")
+    }),
+  )
+
+  it.instance("apply_unified_patch rolls back when any hunk fails", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const file = path.join(test.directory, "file.txt")
+      yield* put(file, "alpha\nbeta\n")
+
+      const error = yield* fail(ApplyUnifiedPatchTool, {
+        patch: ["--- a/file.txt", "+++ b/file.txt", "@@ -1,2 +1,2 @@", " alpha", "-missing", "+gamma", ""].join(
+          "\n",
+        ),
+      })
+
+      expect(error.message).toContain("PATCH_APPLY_ERROR")
+      expect(yield* load(file)).toBe("alpha\nbeta\n")
+    }),
+  )
+
+  it.instance("edit_transaction applies multiple edits across distinct files atomically", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const a = path.join(test.directory, "a.ts")
+      const b = path.join(test.directory, "b.ts")
+      yield* put(a, "export const a = 1\n")
+      yield* put(b, "export const b = 1\n")
+
+      yield* run(EditTransactionTool, {
+        edits: [
+          { tool: "replace_exact", file: a, old: "const a = 1", new: "const a = 2" },
+          { tool: "replace_exact", file: b, old: "const b = 1", new: "const b = 2" },
+        ],
+      })
+
+      expect(yield* load(a)).toBe("export const a = 2\n")
+      expect(yield* load(b)).toBe("export const b = 2\n")
+    }),
+  )
+
+  it.instance("edit_transaction rolls back every edit when one fails", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const a = path.join(test.directory, "a.ts")
+      const b = path.join(test.directory, "b.ts")
+      yield* put(a, "export const a = 1\n")
+      yield* put(b, "export const b = 1\n")
+
+      const error = yield* fail(EditTransactionTool, {
+        edits: [
+          { tool: "replace_exact", file: a, old: "const a = 1", new: "const a = 2" },
+          { tool: "replace_exact", file: b, old: "MISSING", new: "x" },
+        ],
+      })
+
+      expect(error.message).toContain("OLD_TEXT_NOT_FOUND")
+      expect(yield* load(a)).toBe("export const a = 1\n")
+      expect(yield* load(b)).toBe("export const b = 1\n")
+    }),
+  )
+
+  it.instance("edit_transaction composes multiple edits to the same file sequentially", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const a = path.join(test.directory, "a.ts")
+      yield* put(a, "export const a = 1\nexport const c = 1\n")
+
+      yield* run(EditTransactionTool, {
+        edits: [
+          { tool: "replace_exact", file: a, old: "const a = 1", new: "const a = 2" },
+          { tool: "replace_exact", file: a, old: "const c = 1", new: "const c = 2" },
+        ],
+      })
+
+      expect(yield* load(a)).toBe("export const a = 2\nexport const c = 2\n")
+    }),
+  )
+
+  it.instance("edit_transaction keeps same-file edits atomic when a later edit fails", () =>
+    Effect.gen(function* () {
+      const test = yield* TestInstance
+      const a = path.join(test.directory, "a.ts")
+      yield* put(a, "export const a = 1\nexport const c = 1\n")
+
+      const error = yield* fail(EditTransactionTool, {
+        edits: [
+          { tool: "replace_exact", file: a, old: "const a = 1", new: "const a = 2" },
+          { tool: "replace_exact", file: a, old: "const missing = 1", new: "const missing = 2" },
+        ],
+      })
+
+      expect(error.message).toContain("OLD_TEXT_NOT_FOUND")
+      expect(yield* load(a)).toBe("export const a = 1\nexport const c = 1\n")
+    }),
+  )
+
+})
diff --git a/packages/opencode/test/tool/lsp_symbol.test.ts b/packages/opencode/test/tool/lsp_symbol.test.ts
new file mode 100644
index 0000000..d390cc9
--- /dev/null
+++ b/packages/opencode/test/tool/lsp_symbol.test.ts
@@ -0,0 +1,257 @@
+import { afterEach, describe, expect } from "bun:test"
+import path from "path"
+import { createHash } from "crypto"
+import { Cause, Effect, Exit, Layer } from "effect"
+import { Agent } from "@/agent/agent"
+import { EventV2Bridge } from "@/event-v2-bridge"
+import { Format } from "@/format"
+import { LSP } from "@/lsp/lsp"
+import { MessageID, SessionID } from "@/session/schema"
+import { LspSymbolTool } from "@/tool/lsp_symbol"
+import { Truncate } from "@/tool/truncate"
+import * as Tool from "@/tool/tool"
+import { FSUtil } from "@opencode-ai/core/fs-util"
+import { disposeAllInstances, TestInstance } from "../fixture/fixture"
+import { testEffect } from "../lib/effect"
+
+const ctx = {
+  sessionID: SessionID.make("ses_test-lsp-symbol-session"),
+  messageID: MessageID.make("msg_test"),
+  callID: "",
+  agent: "build",
+  abort: AbortSignal.any([]),
+  messages: [],
+  metadata: () => Effect.void,
+  ask: () => Effect.void,
+}
+
+afterEach(async () => {
+  await disposeAllInstances()
+})
+
+// Mutable knobs the mock LSP layer reads, so each test can stage its own
+// documentSymbol() result and client availability without rebuilding layers.
+let nextSymbols: unknown[] = []
+let clientsAvailable = true
+const touched: string[] = []
+
+const mockLSP = Layer.succeed(
+  LSP.Service,
+  LSP.Service.of({
+    init: () => Effect.void,
+    status: () => Effect.succeed([]),
+    hasClients: () => Effect.succeed(clientsAvailable),
+    touchFile: (file) =>
+      Effect.sync(() => {
+        touched.push(file)
+      }),
+    diagnostics: () => Effect.succeed({}),
+    hover: () => Effect.succeed([]),
+    definition: () => Effect.succeed([]),
+    references: () => Effect.succeed([]),
+    implementation: () => Effect.succeed([]),
+    documentSymbol: () => Effect.succeed(nextSymbols as never),
+    workspaceSymbol: () => Effect.succeed([]),
+    prepareCallHierarchy: () => Effect.succeed([]),
+    incomingCalls: () => Effect.succeed([]),
+    outgoingCalls: () => Effect.succeed([]),
+  }),
+)
+
+const layer = Layer.mergeAll(
+  mockLSP,
+  FSUtil.defaultLayer,
+  Format.defaultLayer,
+  EventV2Bridge.defaultLayer,
+  Truncate.defaultLayer,
+  Agent.defaultLayer,
+)
+
+const it = testEffect(layer)
+
+const put = Effect.fn("LspSymbolTest.put")(function* (file: string, content: string) {
+  const fs = yield* FSUtil.Service
+  yield* fs.writeWithDirs(file, content)
+})
+
+const load = Effect.fn("LspSymbolTest.load")(function* (file: string) {
+  const fs = yield* FSUtil.Service
+  return yield* fs.readFileString(file)
+})
+
+const sha256 = (content: string) => createHash("sha256").update(content).digest("hex")
+
+const run = Effect.fn("LspSymbolTest.run")(function* (args: Record<string, unknown>) {
+  const resolved = yield* LspSymbolTool
+  const tool = yield* resolved.init()
+  const execute = tool.execute as unknown as (
+    input: Record<string, unknown>,
+    next: Tool.Context,
+  ) => Effect.Effect<Tool.ExecuteResult>
+  return yield* execute(args, ctx)
+})
+
+const fail = Effect.fn("LspSymbolTest.fail")(function* (args: Record<string, unknown>) {
+  const exit = yield* run(args).pipe(Effect.exit)
+  if (Exit.isFailure(exit)) {
+    const err = Cause.squash(exit.cause)
+    return err instanceof Error ? err : new Error(String(err))
+  }
+  throw new Error("expected lsp_symbol to fail")
+})
+
+// A Go-ish source where Foo spans lines 2..4 (0-based) and Bar spans 6..8.
+// gopls reports a function's range as the start of `func` through just past the
+// closing `}`, which is what these ranges encode.
+const GO_SRC = "package main\n\nfunc Foo() int {\n\treturn 1\n}\n\nfunc Bar() int {\n\treturn 2\n}\n"
+const fooRange = { start: { line: 2, character: 0 }, end: { line: 4, character: 1 } }
+const barRange = { start: { line: 6, character: 0 }, end: { line: 8, character: 1 } }
+
+describe("tool.lsp_symbol", () => {
+  it.instance("replaces a hierarchical DocumentSymbol's full range", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "main.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [
+        { name: "Foo", range: fooRange },
+        { name: "Bar", range: barRange },
+      ]
+      clientsAvailable = true
+
+      const result = yield* run({ file, name: "Foo", new_text: "func Foo() int {\n\treturn 100\n}" })
+
+      // Only Foo's range is rewritten; Bar and surrounding text are untouched.
+      expect(yield* load(file)).toBe(
+        "package main\n\nfunc Foo() int {\n\treturn 100\n}\n\nfunc Bar() int {\n\treturn 2\n}\n",
+      )
+      expect(result.metadata.ok).toBe(true)
+      expect(result.metadata.tool).toBe("lsp_symbol")
+      expect(result.metadata.files_changed).toEqual([file])
+      expect(touched).toContain(file)
+    }),
+  )
+
+  it.instance("replaces a flat SymbolInformation entry using its location range", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "flat.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [
+        { name: "Foo", location: { range: fooRange }, containerName: "main" },
+        { name: "Bar", location: { range: barRange }, containerName: "main" },
+      ]
+
+      yield* run({ file, name: "Bar", new_text: "func Bar() int {\n\treturn 200\n}" })
+
+      expect(yield* load(file)).toBe(
+        "package main\n\nfunc Foo() int {\n\treturn 1\n}\n\nfunc Bar() int {\n\treturn 200\n}\n",
+      )
+    }),
+  )
+
+  it.instance("disambiguates same-named symbols by container", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "methods.go")
+      // Two String() methods, one per type; ranges 2..4 and 6..8.
+      const src =
+        "package main\n\nfunc String() int {\n\treturn 1\n}\n\nfunc String() int {\n\treturn 2\n}\n"
+      yield* put(file, src)
+      nextSymbols = [
+        { name: "A", range: { start: { line: 2, character: 0 }, end: { line: 4, character: 1 } }, children: [
+          { name: "String", range: { start: { line: 2, character: 0 }, end: { line: 4, character: 1 } } },
+        ] },
+        { name: "B", range: { start: { line: 6, character: 0 }, end: { line: 8, character: 1 } }, children: [
+          { name: "String", range: { start: { line: 6, character: 0 }, end: { line: 8, character: 1 } } },
+        ] },
+      ]
+
+      yield* run({ file, name: "String", container: "B", new_text: "func String() int {\n\treturn 99\n}" })
+
+      expect(yield* load(file)).toBe(
+        "package main\n\nfunc String() int {\n\treturn 1\n}\n\nfunc String() int {\n\treturn 99\n}\n",
+      )
+    }),
+  )
+
+  it.instance("rejects ambiguous symbols without a container and leaves the file intact", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "dupe.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [
+        { name: "Foo", range: fooRange },
+        { name: "Foo", range: barRange },
+      ]
+
+      const error = yield* fail({ file, name: "Foo", new_text: "func Foo() int { return 0 }" })
+
+      expect(error.message).toContain("SYMBOL_NOT_UNIQUE")
+      expect(yield* load(file)).toBe(GO_SRC)
+    }),
+  )
+
+  it.instance("reports SYMBOL_NOT_FOUND when the LSP knows no such symbol", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "missing.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [{ name: "Foo", range: fooRange }]
+
+      const error = yield* fail({ file, name: "Nope", new_text: "x" })
+
+      expect(error.message).toContain("SYMBOL_NOT_FOUND")
+      expect(yield* load(file)).toBe(GO_SRC)
+    }),
+  )
+
+  it.instance("reports LSP_UNAVAILABLE when no client is attached", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "noclient.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [{ name: "Foo", range: fooRange }]
+      clientsAvailable = false
+
+      const error = yield* fail({ file, name: "Foo", new_text: "func Foo() int { return 0 }" })
+
+      expect(error.message).toContain("LSP_UNAVAILABLE")
+      expect(yield* load(file)).toBe(GO_SRC)
+      clientsAvailable = true
+    }),
+  )
+
+  it.instance("rejects a stale expected_sha256 before touching the file", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "hash.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [{ name: "Foo", range: fooRange }]
+
+      const error = yield* fail({
+        file,
+        name: "Foo",
+        new_text: "func Foo() int {\n\treturn 100\n}",
+        expected_sha256: sha256("stale contents\n"),
+      })
+
+      expect(error.message).toContain("HASH_MISMATCH")
+      expect(yield* load(file)).toBe(GO_SRC)
+    }),
+  )
+
+  it.instance("rejects empty new_text as NO_CHANGES", () =>
+    Effect.gen(function* () {
+      const dir = (yield* TestInstance).directory
+      const file = path.join(dir, "empty.go")
+      yield* put(file, GO_SRC)
+      nextSymbols = [{ name: "Foo", range: fooRange }]
+
+      const error = yield* fail({ file, name: "Foo", new_text: "" })
+
+      expect(error.message).toContain("NO_CHANGES")
+      expect(yield* load(file)).toBe(GO_SRC)
+    }),
+  )
+})
