diff --git a/packages/opencode/EDIT_STRATEGY_BENCHMARK.md b/packages/opencode/EDIT_STRATEGY_BENCHMARK.md
new file mode 100644
index 0000000..48049a4
--- /dev/null
+++ b/packages/opencode/EDIT_STRATEGY_BENCHMARK.md
@@ -0,0 +1,115 @@
+# Edit Tool Benchmark Notes
+
+This branch has two benchmark surfaces:
+
+1. The original OpenCode `edit` tool with swappable internal matching strategies.
+2. Independent edit tools with distinct model-facing schemas.
+
+`write` is intentionally unchanged.
+
+## Independent Tools
+
+The independently exposed tools are:
+
+- `apply_unified_patch`: standard unified diff, pre-verifies every file, writes atomically after permission.
+- `replace_exact`: exact text replacement with occurrence and optional sha256 checks.
+- `replace_by_anchor`: literal start/end anchor range replacement with uniqueness and max-range checks.
+- `insert_by_anchor`: literal anchor insertion with uniqueness and duplicate-guard checks.
+- `replace_symbol_body`: TypeScript/JavaScript parser-backed symbol body replacement.
+- `structured_data_edit`: JSON/JSONC parser-backed path operations.
+
+All successful independent tools return benchmark-friendly metadata:
+
+- `ok`
+- `tool`
+- `files_changed`
+- `changed_lines`
+- `diff`
+- `warnings`
+- `requires_reread`
+- `postcheck`
+
+Known first-pass boundaries:
+
+- `structured_data_edit` rejects YAML/TOML with `UNSUPPORTED_FORMAT` until parser-backed implementations are added.
+- `replace_symbol_body` supports TypeScript/JavaScript only; Python/Go are intentionally not guessed with text heuristics.
+
+To run one independent edit tool at a time, set `OPENCODE_EDIT_TOOL`:
+
+```bash
+for tool in apply_unified_patch replace_exact replace_by_anchor insert_by_anchor replace_symbol_body structured_data_edit; do
+  OPENCODE_EDIT_TOOL="$tool" \
+    <swe-bench-pro-runner-command> \
+    --output "runs/swebench-pro-$tool.jsonl"
+done
+```
+
+Supported selector values:
+
+- one tool id from the list above: expose only that independent edit tool, while keeping `write`.
+- `all`: expose all independent edit tools.
+- `legacy`: hide independent edit tools and keep OpenCode's legacy `edit` / `apply_patch` behavior.
+
+## Original Edit Strategy Baseline
+
+OpenCode's model-facing `edit` tool schema is unchanged:
+
+```json
+{
+  "filePath": "/absolute/path",
+  "oldString": "text to replace",
+  "newString": "replacement text",
+  "replaceAll": false
+}
+```
+
+The implementation can be swapped by setting `OPENCODE_EDIT_STRATEGY` before running
+the agent. This keeps model prompts and tool-call shape constant, so SWE-bench Pro runs
+measure the edit engine rather than a new tool API.
+
+## Strategies
+
+- `fuzzy`: current OpenCode behavior; tries exact match, trimmed-line match, block anchors,
+  whitespace normalization, indentation-flexible matching, escape normalization, trimmed
+  boundaries, context matching, and multi-occurrence matching.
+- `exact`: exact `oldString` matching only.
+- `line_trimmed`: exact, then line-trimmed matching.
+- `block_anchor`: exact, then block-anchor matching.
+- `whitespace`: exact, then whitespace-normalized matching.
+- `indentation`: exact, then indentation-flexible matching.
+- `escape`: exact, then escape-normalized matching.
+- `trimmed_boundary`: exact, then boundary-trimmed matching.
+- `context`: exact, then context-aware matching.
+- `multi_occurrence`: exact, then multi-occurrence matching.
+
+Each successful edit records these fields in tool metadata:
+
+- `editStrategy`: the selected strategy.
+- `replacements`: number of replacements applied to the matched span.
+
+## Example
+
+```bash
+OPENCODE_EDIT_STRATEGY=exact bun run --cwd packages/opencode src/index.ts --help
+```
+
+For SWE-bench Pro, run the same harness repeatedly with one strategy per run, for example:
+
+```bash
+for strategy in fuzzy exact line_trimmed block_anchor whitespace indentation escape trimmed_boundary context multi_occurrence; do
+  OPENCODE_EDIT_STRATEGY="$strategy" \
+    <swe-bench-pro-runner-command> \
+    --output "runs/swebench-pro-$strategy.jsonl"
+done
+```
+
+Recommended comparison metrics:
+
+- resolved rate
+- edit tool failure rate
+- `oldString` not found rate
+- multiple-match rate
+- malformed/no-op edit rate
+- average edit calls per instance
+- average changed lines per accepted edit
+- tool metadata distribution by `editStrategy`
diff --git a/packages/opencode/src/tool/apply_unified_patch.ts b/packages/opencode/src/tool/apply_unified_patch.ts
new file mode 100644
index 0000000..0bdaa2b
--- /dev/null
+++ b/packages/opencode/src/tool/apply_unified_patch.ts
@@ -0,0 +1,123 @@
+import path from "path"
+import { applyPatch, parsePatch } from "diff"
+import { Effect, Schema } from "effect"
+import { InstanceState } from "@/effect/instance-state"
+import * as Tool from "./tool"
+import DESCRIPTION from "./apply_unified_patch.txt"
+import {
+  captureEditToolkitServices,
+  commitFileChanges,
+  editError,
+  readExistingTextFile,
+  resolveToolFile,
+  verifySha256,
+  type EditPlan,
+  type EditToolkitServices,
+  type PlannedFileChange,
+} from "./edit_toolkit"
+import { assertExternalDirectoryEffect } from "./external-directory"
+import type { Context } from "./tool"
+
+export const Parameters = Schema.Struct({
+  patch: Schema.String.annotate({ description: "A standard unified diff patch." }),
+  expected_files: Schema.optional(Schema.Record(Schema.String, Schema.String)).annotate({
+    description: "Optional map of file path to expected current sha256.",
+  }),
+  allow_fuzz: Schema.optional(Schema.Boolean).annotate({
+    description: "Allow fuzzy hunk matching. Defaults to false.",
+  }),
+})
+
+export const planApplyUnifiedPatch = (
+  services: EditToolkitServices,
+  ctx: Context,
+  params: Schema.Schema.Type<typeof Parameters>,
+) =>
+  Effect.gen(function* () {
+    if (params.patch.trim() === "") throw editError("PATCH_PARSE_ERROR", "patch must not be empty")
+    const instance = yield* InstanceState.context
+    const patches = parsePatchOrThrow(params.patch)
+    if (patches.length === 0) throw editError("PATCH_PARSE_ERROR", "no file patches found")
+
+    const changes = yield* Effect.forEach(patches, (patch) =>
+      Effect.gen(function* () {
+        const kind = patchKind(patch.oldFileName, patch.newFileName)
+        const patchFile = normalizePatchFileName(kind === "delete" ? patch.oldFileName : patch.newFileName)
+        if (!patchFile) throw editError("PATCH_PARSE_ERROR", "patch file path is missing")
+        const filePath = resolveToolFile(instance, patchFile)
+        yield* assertExternalDirectoryEffect(ctx, filePath)
+        const expected = expectedHash(params.expected_files, filePath, path.relative(instance.directory, filePath))
+
+        if (kind === "add") {
+          if (yield* services.fs.existsSafe(filePath)) throw editError("PATCH_APPLY_ERROR", `${filePath} already exists`)
+          const applied = applyPatchOrThrow("", patch, params.allow_fuzz ?? false)
+          return { filePath, oldContent: "", newContent: applied.content, bom: false, kind, fuzzy: applied.fuzzy }
+        }
+
+        const source = yield* readExistingTextFile(services.fs, filePath)
+        yield* verifySha256(services.fs, filePath, expected)
+        const applied = applyPatchOrThrow(source.text, patch, params.allow_fuzz ?? false)
+        return { filePath, oldContent: source.text, newContent: applied.content, bom: source.bom, kind, fuzzy: applied.fuzzy }
+      }),
+    )
+
+    // Only warn about fuzz when a hunk actually required it, not merely because
+    // the caller permitted it.
+    const fuzzyApplied = changes.some((change) => change.fuzzy)
+    return {
+      changes: changes.map(({ fuzzy: _fuzzy, ...change }) => change satisfies PlannedFileChange),
+      warnings: fuzzyApplied ? ["fuzzy_applied=true"] : [],
+    } satisfies EditPlan
+  })
+
+export const ApplyUnifiedPatchTool = Tool.define(
+  "apply_unified_patch",
+  Effect.gen(function* () {
+    const services = yield* captureEditToolkitServices
+    return {
+      description: DESCRIPTION,
+      parameters: Parameters,
+      execute: (params: Schema.Schema.Type<typeof Parameters>, ctx: Tool.Context) =>
+        Effect.gen(function* () {
+          const plan = yield* planApplyUnifiedPatch(services, ctx, params)
+          return yield* commitFileChanges(services, { tool: "apply_unified_patch", ctx, ...plan })
+        }).pipe(Effect.orDie),
+    }
+  }),
+)
+
+function parsePatchOrThrow(patch: string) {
+  try {
+    return parsePatch(patch)
+  } catch (error) {
+    throw editError("PATCH_PARSE_ERROR", error instanceof Error ? error.message : String(error))
+  }
+}
+
+function applyPatchOrThrow(content: string, patch: ReturnType<typeof parsePatch>[number], allowFuzz: boolean) {
+  // Try a strict apply first so we can tell whether fuzz was genuinely needed.
+  const strict = applyPatch(content, patch, { fuzzFactor: 0, autoConvertLineEndings: true })
+  if (strict !== false) return { content: strict, fuzzy: false }
+  if (allowFuzz) {
+    const fuzzy = applyPatch(content, patch, { fuzzFactor: 2, autoConvertLineEndings: true })
+    if (fuzzy !== false) return { content: fuzzy, fuzzy: true }
+  }
+  throw editError("PATCH_APPLY_ERROR", `failed to apply patch for ${patch.newFileName}`)
+}
+
+function patchKind(oldFileName: string | undefined, newFileName: string | undefined): PlannedFileChange["kind"] {
+  if (oldFileName === "/dev/null") return "add"
+  if (newFileName === "/dev/null") return "delete"
+  return "update"
+}
+
+function normalizePatchFileName(fileName: string | undefined) {
+  if (!fileName || fileName === "/dev/null") return undefined
+  const withoutPrefix = fileName.startsWith("a/") || fileName.startsWith("b/") ? fileName.slice(2) : fileName
+  return withoutPrefix.replace(/^"|"$/g, "")
+}
+
+function expectedHash(expectedFiles: Record<string, string> | undefined, filePath: string, relativePath: string) {
+  if (!expectedFiles) return undefined
+  return expectedFiles[filePath] ?? expectedFiles[relativePath] ?? expectedFiles[`a/${relativePath}`] ?? expectedFiles[`b/${relativePath}`]
+}
diff --git a/packages/opencode/src/tool/apply_unified_patch.txt b/packages/opencode/src/tool/apply_unified_patch.txt
new file mode 100644
index 0000000..33fd5bd
--- /dev/null
+++ b/packages/opencode/src/tool/apply_unified_patch.txt
@@ -0,0 +1,8 @@
+Apply a standard unified diff patch, optionally across multiple files. Every file is verified before anything is written, so a failure leaves no partial changes. Fuzz is disabled unless `allow_fuzz` is set; when fuzz is actually used, the result reports `fuzzy_applied=true`. Use `/dev/null` as the old or new path to add or delete a file.
+
+Example: change one line and create a new file in a single patch.
+{
+  "patch": "--- a/file.txt\n+++ b/file.txt\n@@ -1,2 +1,2 @@\n alpha\n-beta\n+gamma\n--- /dev/null\n+++ b/new.txt\n@@ -0,0 +1 @@\n+created\n"
+}
+
+Pass `expected_files` (a map of path to expected current sha256) to reject the patch if any target file changed since you read it. Patches are sensitive to line numbers and context — generate them from the current file contents.
diff --git a/packages/opencode/src/tool/edit_plans.ts b/packages/opencode/src/tool/edit_plans.ts
new file mode 100644
index 0000000..f6c8dba
--- /dev/null
+++ b/packages/opencode/src/tool/edit_plans.ts
@@ -0,0 +1,40 @@
+import { Effect, Schema } from "effect"
+import { editError, type EditPlan, type EditToolkitServices } from "./edit_toolkit"
+import type { Context } from "./tool"
+import { Parameters as ApplyUnifiedPatchParameters, planApplyUnifiedPatch } from "./apply_unified_patch"
+import { Parameters as InsertByAnchorParameters, planInsertByAnchor } from "./insert_by_anchor"
+import { Parameters as ReplaceByAnchorParameters, planReplaceByAnchor } from "./replace_by_anchor"
+import { Parameters as ReplaceExactParameters, planReplaceExact } from "./replace_exact"
+
+// A planner validates a raw edit spec against its tool's parameter schema and
+// produces an EditPlan without touching disk. edit_transaction dispatches through
+// this table to batch several primitive edits atomically.
+type Planner = {
+  schema: Schema.Schema<any>
+  plan: (services: EditToolkitServices, ctx: Context, params: any) => Effect.Effect<EditPlan, any, never>
+}
+
+const planners: Record<string, Planner> = {
+  replace_exact: { schema: ReplaceExactParameters, plan: planReplaceExact },
+  replace_by_anchor: { schema: ReplaceByAnchorParameters, plan: planReplaceByAnchor },
+  insert_by_anchor: { schema: InsertByAnchorParameters, plan: planInsertByAnchor },
+  apply_unified_patch: { schema: ApplyUnifiedPatchParameters, plan: planApplyUnifiedPatch },
+}
+
+export const EDIT_PLAN_TOOL_IDS = Object.keys(planners)
+
+export type EditSpec = { tool: string } & Record<string, unknown>
+
+export const planEdit = (services: EditToolkitServices, ctx: Context, spec: EditSpec) =>
+  Effect.gen(function* () {
+    const { tool, ...rest } = spec
+    const planner = planners[tool]
+    if (!planner) throw editError("UNKNOWN_EDIT_TOOL", `unknown edit tool: ${tool}`)
+    // The generic schema alias leaves the decoder's requirement channel as
+    // `unknown`; these schemas need no services, so pin it to `never`.
+    const decode = Schema.decodeUnknownEffect(planner.schema)(rest) as Effect.Effect<unknown, unknown, never>
+    const params = yield* decode.pipe(
+      Effect.mapError((error) => editError("INVALID_EDIT_SPEC", `invalid params for ${tool}: ${error}`)),
+    )
+    return yield* planner.plan(services, ctx, params)
+  })
diff --git a/packages/opencode/src/tool/edit_toolkit.ts b/packages/opencode/src/tool/edit_toolkit.ts
new file mode 100644
index 0000000..f551ac2
--- /dev/null
+++ b/packages/opencode/src/tool/edit_toolkit.ts
@@ -0,0 +1,259 @@
+import path from "path"
+import { createHash } from "crypto"
+import { Effect } from "effect"
+import { createTwoFilesPatch, diffLines } from "diff"
+import { EventV2 } from "@opencode-ai/core/event"
+import { EventV2Bridge } from "@/event-v2-bridge"
+import { Format } from "@/format"
+import { InstanceState } from "@/effect/instance-state"
+import type { InstanceContext } from "@/project/instance-context"
+import { LSP } from "@/lsp/lsp"
+import { trimDiff } from "@/tool/edit"
+import type { Context, ExecuteResult } from "@/tool/tool"
+import * as Bom from "@/util/bom"
+import { FileSystem } from "@opencode-ai/core/filesystem"
+import { FSUtil } from "@opencode-ai/core/fs-util"
+import { Watcher } from "@opencode-ai/core/filesystem/watcher"
+import { assertExternalDirectoryEffect } from "./external-directory"
+
+export type FileChangeKind = "add" | "update" | "delete"
+
+export type PlannedFileChange = {
+  filePath: string
+  oldContent: string
+  newContent: string
+  bom: boolean
+  kind: FileChangeKind
+}
+
+export type EditPostcheck = {
+  parsed?: boolean
+  formatted?: boolean
+}
+
+// The pure result of an edit before it is committed: each tool builds an
+// EditPlan, then commits it via commitFileChanges.
+export type EditPlan = {
+  changes: PlannedFileChange[]
+  warnings?: string[]
+  postcheck?: EditPostcheck
+}
+
+type Diagnostics = Record<string, Parameters<typeof LSP.Diagnostic.report>[1]>
+
+export type EditToolkitServices = {
+  fs: FSUtil.Interface
+  lsp: LSP.Interface
+  format: Format.Interface
+  events: EventV2.Interface
+}
+
+export const captureEditToolkitServices = Effect.gen(function* () {
+  return {
+    fs: yield* FSUtil.Service,
+    lsp: yield* LSP.Service,
+    format: yield* Format.Service,
+    events: yield* EventV2Bridge.Service,
+  } satisfies EditToolkitServices
+})
+
+export type EditToolkitMetadata = {
+  ok: true
+  tool: string
+  files_changed: string[]
+  changed_lines: number
+  diff: string
+  warnings: string[]
+  requires_reread: true
+  postcheck: EditPostcheck
+  diagnostics: Diagnostics
+  files: Array<{
+    filePath: string
+    relativePath: string
+    type: FileChangeKind
+    patch: string
+    additions: number
+    deletions: number
+  }>
+}
+
+export function editError(code: string, message: string) {
+  return new Error(`${code}: ${message}`)
+}
+
+export function normalizeLineEndings(text: string): string {
+  return text.replaceAll("\r\n", "\n")
+}
+
+export function detectLineEnding(text: string): "\n" | "\r\n" {
+  return text.includes("\r\n") ? "\r\n" : "\n"
+}
+
+export function convertToLineEnding(text: string, ending: "\n" | "\r\n"): string {
+  if (ending === "\n") return normalizeLineEndings(text)
+  return normalizeLineEndings(text).replaceAll("\n", "\r\n")
+}
+
+export function resolveToolFile(instance: InstanceContext, file: string) {
+  return path.isAbsolute(file) ? file : path.join(instance.directory, file)
+}
+
+export function countOccurrences(content: string, search: string) {
+  if (search === "") return 0
+  return content.split(search).length - 1
+}
+
+export const readExistingTextFile = Effect.fn("EditToolkit.readExistingTextFile")(function* (
+  fs: FSUtil.Interface,
+  filePath: string,
+) {
+  const info = yield* fs.stat(filePath).pipe(Effect.catch(() => Effect.succeed(undefined)))
+  if (!info) throw editError("FILE_NOT_FOUND", `${filePath} was not found`)
+  if (info.type === "Directory") throw editError("FILE_IS_DIRECTORY", `${filePath} is a directory`)
+  return yield* Bom.readFile(fs, filePath)
+})
+
+export const verifySha256 = Effect.fn("EditToolkit.verifySha256")(function* (
+  fs: FSUtil.Interface,
+  filePath: string,
+  expectedSha256?: string,
+) {
+  if (!expectedSha256) return
+  const actual = createHash("sha256").update(yield* fs.readFile(filePath)).digest("hex")
+  if (actual !== expectedSha256) {
+    throw editError("HASH_MISMATCH", `${filePath} sha256 was ${actual}, expected ${expectedSha256}`)
+  }
+})
+
+export const commitFileChanges = Effect.fn("EditToolkit.commitFileChanges")(function* (
+  services: EditToolkitServices,
+  input: {
+    tool: string
+    ctx: Context
+    changes: PlannedFileChange[]
+    warnings?: string[]
+    postcheck?: EditPostcheck
+  },
+) {
+  if (input.changes.length === 0) throw editError("NO_CHANGES", "no file changes were planned")
+  const instance = yield* InstanceState.context
+
+  const filesBeforeFormat = input.changes.map((change) => fileInfo(instance, change))
+  const totalDiff = filesBeforeFormat.map((file) => file.patch).join("\n")
+  const relativePaths = filesBeforeFormat.map((file) => file.relativePath)
+
+  yield* input.ctx.ask({
+    permission: "edit",
+    patterns: relativePaths,
+    always: ["*"],
+    metadata: {
+      filepath: relativePaths.join(", "),
+      diff: totalDiff,
+      files: filesBeforeFormat,
+    },
+  })
+
+  const finalized = yield* Effect.forEach(input.changes, (change) =>
+    Effect.gen(function* () {
+      if (change.kind === "delete") {
+        yield* services.fs.remove(change.filePath)
+        yield* services.events.publish(Watcher.Event.Updated, { file: change.filePath, event: "unlink" })
+        return { ...change, formatted: false }
+      }
+
+      yield* services.fs.writeWithDirs(change.filePath, Bom.join(change.newContent, change.bom))
+      const formatted = yield* services.format.file(change.filePath)
+      const newContent = formatted ? yield* Bom.syncFile(services.fs, change.filePath, change.bom) : change.newContent
+      yield* services.events.publish(FileSystem.Event.Edited, { file: change.filePath })
+      yield* services.events.publish(Watcher.Event.Updated, {
+        file: change.filePath,
+        event: change.kind === "add" ? "add" : "change",
+      })
+      return { ...change, newContent, formatted }
+    }),
+  )
+
+  for (const change of finalized) {
+    if (change.kind === "delete") continue
+    yield* services.lsp.touchFile(change.filePath, "document")
+  }
+  const diagnostics = yield* services.lsp.diagnostics()
+
+  const files = finalized.map((change) => fileInfo(instance, change))
+  const diff = files.map((file) => file.patch).join("\n")
+  const changedLines = files.reduce((sum, file) => sum + file.additions + file.deletions, 0)
+  const postcheck = {
+    ...input.postcheck,
+    formatted: finalized.some((change) => change.formatted) || input.postcheck?.formatted,
+  }
+  const metadata: EditToolkitMetadata = {
+    ok: true,
+    tool: input.tool,
+    files_changed: finalized.map((change) => change.filePath),
+    changed_lines: changedLines,
+    diff,
+    warnings: input.warnings ?? [],
+    requires_reread: true,
+    postcheck,
+    diagnostics,
+    files,
+  }
+  const output = [
+    `${input.tool} applied successfully.`,
+    ...files.map((file) => `${file.type.toUpperCase()} ${file.relativePath}`),
+  ].join("\n")
+
+  return {
+    title: files.map((file) => file.relativePath).join(", "),
+    metadata,
+    output: outputWithDiagnostics(output, finalized, diagnostics),
+  } satisfies ExecuteResult<EditToolkitMetadata>
+})
+
+function fileInfo(instance: InstanceContext, change: PlannedFileChange) {
+  const patch = trimDiff(
+    createTwoFilesPatch(
+      change.filePath,
+      change.filePath,
+      normalizeLineEndings(change.oldContent),
+      normalizeLineEndings(change.newContent),
+    ),
+  )
+  let additions = 0
+  let deletions = 0
+  for (const item of diffLines(change.oldContent, change.newContent)) {
+    if (item.added) additions += item.count || 0
+    if (item.removed) deletions += item.count || 0
+  }
+  return {
+    filePath: change.filePath,
+    relativePath: path.relative(instance.worktree, change.filePath).replaceAll("\\", "/"),
+    type: change.kind,
+    patch,
+    additions,
+    deletions,
+  }
+}
+
+function outputWithDiagnostics(
+  output: string,
+  changes: Array<PlannedFileChange & { formatted: boolean }>,
+  diagnostics: Diagnostics,
+) {
+  return changes.reduce((result, change) => {
+    if (change.kind === "delete") return result
+    const block = LSP.Diagnostic.report(change.filePath, diagnostics[FSUtil.normalizePath(change.filePath)] ?? [])
+    if (!block) return result
+    return `${result}\n\nLSP errors detected in this file, please fix:\n${block}`
+  }, output)
+}
+
+export const assertEditableFile = Effect.fn("EditToolkit.assertEditableFile")(function* (
+  ctx: Context,
+  fs: FSUtil.Interface,
+  filePath: string,
+) {
+  yield* assertExternalDirectoryEffect(ctx, filePath)
+  const source = yield* readExistingTextFile(fs, filePath)
+  return source
+})
diff --git a/packages/opencode/src/tool/edit_transaction.ts b/packages/opencode/src/tool/edit_transaction.ts
new file mode 100644
index 0000000..b7d0b19
--- /dev/null
+++ b/packages/opencode/src/tool/edit_transaction.ts
@@ -0,0 +1,189 @@
+import { Effect, Schema } from "effect"
+import * as Tool from "./tool"
+import DESCRIPTION from "./edit_transaction.txt"
+import { FSUtil } from "@opencode-ai/core/fs-util"
+import * as Bom from "@/util/bom"
+import {
+  captureEditToolkitServices,
+  commitFileChanges,
+  editError,
+  type EditPlan,
+  type EditToolkitServices,
+  type PlannedFileChange,
+} from "./edit_toolkit"
+import { planEdit, type EditSpec } from "./edit_plans"
+
+export const Parameters = Schema.Struct({
+  edits: Schema.Array(Schema.Record(Schema.String, Schema.Unknown)).annotate({
+    description: "Edits to apply atomically. Each is an object with a `tool` field plus that tool's parameters.",
+  }),
+})
+
+export const EditTransactionTool = Tool.define(
+  "edit_transaction",
+  Effect.gen(function* () {
+    const services = yield* captureEditToolkitServices
+    return {
+      description: DESCRIPTION,
+      parameters: Parameters,
+      execute: (params: Schema.Schema.Type<typeof Parameters>, ctx: Tool.Context) =>
+        Effect.gen(function* () {
+          if (params.edits.length === 0) throw editError("NO_CHANGES", "edits must not be empty")
+
+          // Plan every edit before writing anything. Later edits see earlier
+          // planned changes through an in-memory overlay, so multiple edits can
+          // target the same file while the transaction still commits atomically.
+          const changesByPath = new Map<string, PlannedFileChange>()
+          const warnings: string[] = []
+          let postcheckParsed = false
+
+          for (const spec of params.edits) {
+            if (typeof spec.tool !== "string") throw editError("INVALID_EDIT_SPEC", "each edit needs a string `tool`")
+            const plan = yield* planEdit(overlayServices(services, changesByPath), ctx, spec as EditSpec)
+            for (const change of plan.changes) {
+              mergePlannedChange(changesByPath, change)
+            }
+            warnings.push(...(plan.warnings ?? []))
+            postcheckParsed ||= !!plan.postcheck?.parsed
+          }
+
+          const postcheck = postcheckParsed ? { parsed: true } : undefined
+          return yield* commitFileChanges(services, {
+            tool: "edit_transaction",
+            ctx,
+            changes: [...changesByPath.values()],
+            warnings,
+            postcheck,
+          })
+        }).pipe(Effect.orDie),
+    }
+  }),
+)
+
+function overlayServices(
+  services: EditToolkitServices,
+  changesByPath: ReadonlyMap<string, PlannedFileChange>,
+): EditToolkitServices {
+  return {
+    ...services,
+    fs: overlayFileSystem(services.fs, changesByPath),
+  }
+}
+
+function overlayFileSystem(
+  fs: FSUtil.Interface,
+  changesByPath: ReadonlyMap<string, PlannedFileChange>,
+): FSUtil.Interface {
+  const overlayText = (filePath: string) => {
+    const change = changesByPath.get(filePath)
+    if (!change || change.kind === "delete") return undefined
+    return Bom.join(change.newContent, change.bom)
+  }
+
+  const notFound = (method: string, filePath: string) =>
+    new FSUtil.FileSystemError({ method, cause: new Error(`${filePath} was deleted in this transaction`) })
+
+  return {
+    ...fs,
+    exists: (filePath: string) => {
+      const change = changesByPath.get(filePath)
+      if (change) return Effect.succeed(change.kind !== "delete")
+      return fs.exists(filePath)
+    },
+    existsSafe: (filePath: string) => {
+      const change = changesByPath.get(filePath)
+      if (change) return Effect.succeed(change.kind !== "delete")
+      return fs.existsSafe(filePath)
+    },
+    isFile: (filePath: string) => {
+      const change = changesByPath.get(filePath)
+      if (change) return Effect.succeed(change.kind !== "delete")
+      return fs.isFile(filePath)
+    },
+    isDir: (filePath: string) => {
+      const change = changesByPath.get(filePath)
+      if (change) return Effect.succeed(false)
+      return fs.isDir(filePath)
+    },
+    stat: (filePath: string) => {
+      const change = changesByPath.get(filePath)
+      if (!change) return fs.stat(filePath)
+      if (change.kind === "delete") return Effect.fail(notFound("stat", filePath))
+      return fs.stat(filePath).pipe(Effect.catch(() => Effect.succeed({ type: "File" } as any)))
+    },
+    readFile: (filePath: string) => {
+      const text = overlayText(filePath)
+      if (text !== undefined) return Effect.succeed(new TextEncoder().encode(text))
+      if (changesByPath.get(filePath)?.kind === "delete") return Effect.fail(notFound("readFile", filePath))
+      return fs.readFile(filePath)
+    },
+    readFileString: (filePath: string) => {
+      const text = overlayText(filePath)
+      if (text !== undefined) return Effect.succeed(text)
+      if (changesByPath.get(filePath)?.kind === "delete") return Effect.fail(notFound("readFileString", filePath))
+      return fs.readFileString(filePath)
+    },
+    readFileStringSafe: (filePath: string) => {
+      const text = overlayText(filePath)
+      if (text !== undefined) return Effect.succeed(text)
+      if (changesByPath.get(filePath)?.kind === "delete") return Effect.succeed(undefined)
+      return fs.readFileStringSafe(filePath)
+    },
+  } as FSUtil.Interface
+}
+
+function mergePlannedChange(changesByPath: Map<string, PlannedFileChange>, next: PlannedFileChange) {
+  const prior = changesByPath.get(next.filePath)
+  if (!prior) {
+    changesByPath.set(next.filePath, next)
+    return
+  }
+
+  const merged = squashSequentialChange(prior, next)
+  if (!merged) {
+    changesByPath.delete(next.filePath)
+    return
+  }
+  changesByPath.set(next.filePath, merged)
+}
+
+function squashSequentialChange(prior: PlannedFileChange, next: PlannedFileChange): PlannedFileChange | undefined {
+  if (prior.kind === "add") {
+    if (next.kind === "delete") return undefined
+    return keepIfChanged({
+      ...next,
+      oldContent: "",
+      kind: "add",
+    })
+  }
+
+  if (prior.kind === "delete") {
+    if (next.kind === "add") {
+      return keepIfChanged({
+        ...next,
+        oldContent: prior.oldContent,
+        kind: "update",
+      })
+    }
+    return next
+  }
+
+  if (next.kind === "delete") {
+    return {
+      ...next,
+      oldContent: prior.oldContent,
+      kind: "delete",
+    }
+  }
+
+  return keepIfChanged({
+    ...next,
+    oldContent: prior.oldContent,
+    kind: "update",
+  })
+}
+
+function keepIfChanged(change: PlannedFileChange): PlannedFileChange | undefined {
+  if (change.kind === "update" && change.oldContent === change.newContent) return undefined
+  return change
+}
diff --git a/packages/opencode/src/tool/edit_transaction.txt b/packages/opencode/src/tool/edit_transaction.txt
new file mode 100644
index 0000000..ab9da27
--- /dev/null
+++ b/packages/opencode/src/tool/edit_transaction.txt
@@ -0,0 +1,11 @@
+Apply several edits atomically: all of them succeed and are written together, or none are. Pass an `edits` array; each entry is an object with a `tool` field (replace_exact, replace_by_anchor, insert_by_anchor, or apply_unified_patch) plus that tool's parameters. Every edit is planned and validated first; if any fails, nothing is written. Batching multiple confident edits in one call (instead of one tool call each) keeps large multi-file changes consistent and reduces round-trips.
+
+Edits are planned in order. Later edits see earlier edits in the same transaction, so multiple edits may target the same file. This wrapper only guarantees atomicity — it does not judge whether the change is correct.
+
+Example: change a function and add its test in one shot.
+{
+  "edits": [
+    { "tool": "replace_exact", "file": "src/auth.ts", "old": "return null", "new": "throw new AuthError()" },
+    { "tool": "insert_by_anchor", "file": "src/auth.test.ts", "anchor": "describe('auth', () => {", "position": "after", "content": "\n  it('throws', () => {})" }
+  ]
+}
diff --git a/packages/opencode/src/tool/insert_by_anchor.ts b/packages/opencode/src/tool/insert_by_anchor.ts
new file mode 100644
index 0000000..7bb346b
--- /dev/null
+++ b/packages/opencode/src/tool/insert_by_anchor.ts
@@ -0,0 +1,99 @@
+import { Effect, Schema } from "effect"
+import { InstanceState } from "@/effect/instance-state"
+import * as Tool from "./tool"
+import DESCRIPTION from "./insert_by_anchor.txt"
+import {
+  assertEditableFile,
+  captureEditToolkitServices,
+  commitFileChanges,
+  convertToLineEnding,
+  countOccurrences,
+  detectLineEnding,
+  editError,
+  resolveToolFile,
+  verifySha256,
+  type EditPlan,
+  type EditToolkitServices,
+} from "./edit_toolkit"
+import type { Context } from "./tool"
+
+export const Parameters = Schema.Struct({
+  file: Schema.String.annotate({ description: "The file to edit. Absolute paths are accepted; relative paths resolve in the workspace." }),
+  expected_sha256: Schema.optional(Schema.String).annotate({
+    description: "Optional sha256 of the current file bytes. If provided, the edit is rejected when it does not match.",
+  }),
+  anchor: Schema.String.annotate({ description: "Literal anchor text." }),
+  position: Schema.Literals(["before", "after"]).annotate({ description: "Insert before or after the anchor." }),
+  content: Schema.String.annotate({ description: "Text to insert." }),
+  expected_matches: Schema.optional(Schema.Number).annotate({ description: "Expected anchor occurrence count. Defaults to 1." }),
+  max_insert_lines: Schema.optional(Schema.Number).annotate({ description: "Maximum inserted lines. Defaults to 200." }),
+  must_not_already_contain: Schema.optional(Schema.String).annotate({
+    description: "Optional duplicate guard. If the file already contains this text, the edit is rejected.",
+  }),
+})
+
+export const planInsertByAnchor = (
+  services: EditToolkitServices,
+  ctx: Context,
+  params: Schema.Schema.Type<typeof Parameters>,
+) =>
+  Effect.gen(function* () {
+    if (params.anchor === "") throw editError("ANCHOR_NOT_FOUND", "anchor must not be empty")
+    if (params.content === "") throw editError("NO_CHANGES", "content must not be empty")
+    const lineCount = params.content.split("\n").length
+    if (lineCount > (params.max_insert_lines ?? 200)) {
+      throw editError("MAX_CHANGE_LIMIT_EXCEEDED", `insert has ${lineCount} lines`)
+    }
+    const instance = yield* InstanceState.context
+    const filePath = resolveToolFile(instance, params.file)
+    const source = yield* assertEditableFile(ctx, services.fs, filePath)
+    yield* verifySha256(services.fs, filePath, params.expected_sha256)
+    if (params.must_not_already_contain && source.text.includes(params.must_not_already_contain)) {
+      throw editError("DUPLICATE_INSERT", `${filePath} already contains duplicate guard text`)
+    }
+
+    const ending = detectLineEnding(source.text)
+    const anchor = convertToLineEnding(params.anchor, ending)
+    const content = convertToLineEnding(params.content, ending)
+    const occurrences = countOccurrences(source.text, anchor)
+    const expected = params.expected_matches ?? 1
+    if (occurrences === 0) throw editError("ANCHOR_NOT_FOUND", "anchor was not found")
+    if (occurrences !== expected) {
+      throw editError("ANCHOR_NOT_UNIQUE", `anchor occurred ${occurrences} times, expected ${expected}`)
+    }
+
+    // Insert at every matched anchor. countOccurrences and replaceAll both
+    // use non-overlapping matching, so the count we validated is exactly the
+    // number of insertions performed.
+    const newContent =
+      params.position === "before"
+        ? source.text.replaceAll(anchor, content + anchor)
+        : source.text.replaceAll(anchor, anchor + content)
+    return {
+      changes: [
+        {
+          filePath,
+          oldContent: source.text,
+          newContent,
+          bom: source.bom,
+          kind: "update",
+        },
+      ],
+    } satisfies EditPlan
+  })
+
+export const InsertByAnchorTool = Tool.define(
+  "insert_by_anchor",
+  Effect.gen(function* () {
+    const services = yield* captureEditToolkitServices
+    return {
+      description: DESCRIPTION,
+      parameters: Parameters,
+      execute: (params: Schema.Schema.Type<typeof Parameters>, ctx: Tool.Context) =>
+        Effect.gen(function* () {
