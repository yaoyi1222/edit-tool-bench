+Insert text before or after a literal anchor. Mechanical only: no AST awareness. The anchor must occur exactly `expected_matches` times (default 1); the insertion is performed at every matched anchor. Ideal for adding a test case, a helper, or a config entry without rewriting the file.
+
+Example: add a test case after the describe block opener.
+{
+  "file": "src/auth.test.ts",
+  "anchor": "describe('login', () => {",
+  "position": "after",
+  "content": "\n  it('rejects missing profile', () => {})",
+  "must_not_already_contain": "rejects missing profile"
+}
+
+Use `must_not_already_contain` as a duplicate guard, and `max_insert_lines` (default 200) to cap the inserted size.
diff --git a/packages/opencode/src/tool/lsp_symbol.ts b/packages/opencode/src/tool/lsp_symbol.ts
new file mode 100644
index 0000000..46655e4
--- /dev/null
+++ b/packages/opencode/src/tool/lsp_symbol.ts
@@ -0,0 +1,106 @@
+import { Effect, Schema } from "effect"
+import { pathToFileURL } from "url"
+import { InstanceState } from "@/effect/instance-state"
+import * as Tool from "./tool"
+import DESCRIPTION from "./lsp_symbol.txt"
+import {
+  assertEditableFile,
+  captureEditToolkitServices,
+  commitFileChanges,
+  convertToLineEnding,
+  detectLineEnding,
+  editError,
+  resolveToolFile,
+  verifySha256,
+} from "./edit_toolkit"
+
+export const Parameters = Schema.Struct({
+  file: Schema.String.annotate({ description: "The file to edit. Absolute paths are accepted; relative paths resolve in the workspace." }),
+  name: Schema.String.annotate({ description: "Name of the symbol (function/method/class/...) to replace." }),
+  new_text: Schema.String.annotate({ description: "Full replacement text for the entire symbol (signature + body)." }),
+  container: Schema.optional(Schema.String).annotate({
+    description: "Containing type/class/namespace name, to disambiguate (e.g. a method).",
+  }),
+  expected_sha256: Schema.optional(Schema.String).annotate({
+    description: "Optional sha256 of the current file bytes. If provided, the edit is rejected when it does not match.",
+  }),
+})
+
+// Minimal shapes for the raw LSP documentSymbol result (opencode returns it
+// uncast at runtime): hierarchical DocumentSymbol[] or flat SymbolInformation[].
+type Position = { line: number; character: number }
+type LspRange = { start: Position; end: Position }
+type RawDocumentSymbol = { name: string; range: LspRange; children?: RawDocumentSymbol[] }
+type RawSymbolInformation = { name: string; location: { range: LspRange }; containerName?: string }
+type RawSymbol = RawDocumentSymbol | RawSymbolInformation
+type FlatSymbol = { name: string; range: LspRange; container?: string }
+
+export const LspSymbolTool = Tool.define(
+  "lsp_symbol",
+  Effect.gen(function* () {
+    const services = yield* captureEditToolkitServices
+    return {
+      description: DESCRIPTION,
+      parameters: Parameters,
+      execute: (params: Schema.Schema.Type<typeof Parameters>, ctx: Tool.Context) =>
+        Effect.gen(function* () {
+          if (params.new_text === "") throw editError("NO_CHANGES", "new_text must not be empty")
+          const instance = yield* InstanceState.context
+          const filePath = resolveToolFile(instance, params.file)
+          const source = yield* assertEditableFile(ctx, services.fs, filePath)
+          yield* verifySha256(services.fs, filePath, params.expected_sha256)
+
+          const available = yield* services.lsp.hasClients(filePath)
+          if (!available) throw editError("LSP_UNAVAILABLE", `no LSP server available for ${filePath}`)
+          // Open/index the file so the server can answer documentSymbol.
+          yield* services.lsp.touchFile(filePath, "document")
+
+          const uri = pathToFileURL(filePath).href
+          const symbols = yield* services.lsp.documentSymbol(uri)
+          const flat = flatten(symbols as unknown as RawSymbol[])
+          const matches = flat.filter(
+            (s) => s.name === params.name && (!params.container || s.container === params.container),
+          )
+          if (matches.length === 0) throw editError("SYMBOL_NOT_FOUND", `symbol ${params.name} was not found by LSP in ${filePath}`)
+          if (matches.length > 1) throw editError("SYMBOL_NOT_UNIQUE", `symbol ${params.name} matched ${matches.length} times; pass container`)
+
+          const ending = detectLineEnding(source.text)
+          const start = offsetAt(source.text, matches[0].range.start)
+          const end = offsetAt(source.text, matches[0].range.end)
+          const newContent = source.text.slice(0, start) + convertToLineEnding(params.new_text, ending) + source.text.slice(end)
+          if (newContent === source.text) throw editError("NO_CHANGES", "new_text is identical to the existing symbol")
+
+          return yield* commitFileChanges(services, {
+            tool: "lsp_symbol",
+            ctx,
+            changes: [{ filePath, oldContent: source.text, newContent, bom: source.bom, kind: "update" }],
+            postcheck: { parsed: true },
+          })
+        }).pipe(Effect.orDie),
+    }
+  }),
+)
+
+// Flatten the documentSymbol result (hierarchical DocumentSymbol[] or flat
+// SymbolInformation[]) into name/range/container triples.
+function flatten(symbols: RawSymbol[], parent?: string): FlatSymbol[] {
+  const out: FlatSymbol[] = []
+  for (const sym of symbols) {
+    if ("location" in sym) {
+      out.push({ name: sym.name, range: sym.location.range, container: sym.containerName })
+    } else {
+      out.push({ name: sym.name, range: sym.range, container: parent })
+      if (sym.children?.length) out.push(...flatten(sym.children, sym.name))
+    }
+  }
+  return out
+}
+
+// LSP positions are 0-based {line, character} in UTF-16 code units (matching JS
+// string indexing); convert to a byte/char offset into the file text.
+function offsetAt(text: string, pos: { line: number; character: number }): number {
+  const lines = text.split("\n")
+  let offset = 0
+  for (let i = 0; i < pos.line && i < lines.length; i++) offset += lines[i].length + 1
+  return offset + pos.character
+}
diff --git a/packages/opencode/src/tool/lsp_symbol.txt b/packages/opencode/src/tool/lsp_symbol.txt
new file mode 100644
index 0000000..3e50489
--- /dev/null
+++ b/packages/opencode/src/tool/lsp_symbol.txt
@@ -0,0 +1,12 @@
+Replace a whole symbol (function, method, class, etc.) located via the language server (LSP). Works for any language that has a running LSP server (Go/gopls, Python/pyright, TS-JS/typescript-language-server, …) — unlike text tools it finds the symbol structurally, so it does not depend on exact surrounding text.
+
+The symbol must be unique in the file (use `container` to disambiguate a method by its class). `new_text` REPLACES the entire symbol range (signature + body), so provide the complete new definition. The file is re-checked by the language server after the edit.
+
+Example: rewrite a Go function.
+{
+  "file": "server/events/sse.go",
+  "name": "shouldSend",
+  "new_text": "func (b *broker) shouldSend(...) bool {\n\t// new implementation\n}"
+}
+
+For a method, pass `container` with the type/class name. If the symbol is not found, the LSP server may still be indexing a large repo — read the file first (which warms the server) and retry, or fall back to a text edit tool.
diff --git a/packages/opencode/src/tool/replace_by_anchor.ts b/packages/opencode/src/tool/replace_by_anchor.ts
new file mode 100644
index 0000000..847f01f
--- /dev/null
+++ b/packages/opencode/src/tool/replace_by_anchor.ts
@@ -0,0 +1,120 @@
+import { Effect, Schema } from "effect"
+import { InstanceState } from "@/effect/instance-state"
+import * as Tool from "./tool"
+import DESCRIPTION from "./replace_by_anchor.txt"
+import {
+  assertEditableFile,
+  captureEditToolkitServices,
+  commitFileChanges,
+  convertToLineEnding,
+  detectLineEnding,
+  editError,
+  resolveToolFile,
+  verifySha256,
+  type EditPlan,
+  type EditToolkitServices,
+} from "./edit_toolkit"
+import type { Context } from "./tool"
+
+export const Parameters = Schema.Struct({
+  file: Schema.String.annotate({ description: "The file to edit. Absolute paths are accepted; relative paths resolve in the workspace." }),
+  expected_sha256: Schema.optional(Schema.String).annotate({
+    description: "Optional sha256 of the current file bytes. If provided, the edit is rejected when it does not match.",
+  }),
+  start_anchor: Schema.String.annotate({ description: "Literal text marking the start of the target range." }),
+  end_anchor: Schema.String.annotate({ description: "Literal text marking the end of the target range." }),
+  include_start: Schema.optional(Schema.Boolean).annotate({ description: "Whether to replace the start anchor itself. Defaults to true." }),
+  include_end: Schema.optional(Schema.Boolean).annotate({ description: "Whether to replace the end anchor itself. Defaults to true." }),
+  expected_matches: Schema.optional(Schema.Number).annotate({ description: "Expected number of matching ranges. Defaults to 1." }),
+  max_target_lines: Schema.optional(Schema.Number).annotate({ description: "Maximum target range size in lines. Defaults to 200." }),
+  new: Schema.String.annotate({ description: "Replacement text for the selected range." }),
+})
+
+export const planReplaceByAnchor = (
+  services: EditToolkitServices,
+  ctx: Context,
+  params: Schema.Schema.Type<typeof Parameters>,
+) =>
+  Effect.gen(function* () {
+    if (params.start_anchor === "") throw editError("ANCHOR_NOT_FOUND", "start_anchor must not be empty")
+    if (params.end_anchor === "") throw editError("ANCHOR_NOT_FOUND", "end_anchor must not be empty")
+    const instance = yield* InstanceState.context
+    const filePath = resolveToolFile(instance, params.file)
+    const source = yield* assertEditableFile(ctx, services.fs, filePath)
+    yield* verifySha256(services.fs, filePath, params.expected_sha256)
+
+    const ending = detectLineEnding(source.text)
+    const startAnchor = convertToLineEnding(params.start_anchor, ending)
+    const endAnchor = convertToLineEnding(params.end_anchor, ending)
+    const matches = findAnchorRanges(source.text, startAnchor, endAnchor, {
+      includeStart: params.include_start ?? true,
+      includeEnd: params.include_end ?? true,
+      maxTargetLines: params.max_target_lines ?? 200,
+    })
+    // This tool replaces exactly one range with a single replacement, so it
+    // only ever supports a unique match. Reject expected_matches > 1 up front
+    // instead of silently treating the parameter as inert.
+    const expected = params.expected_matches ?? 1
+    if (expected !== 1) {
+      throw editError("SINGLE_RANGE_ONLY", "replace_by_anchor only edits a single range; expected_matches must be 1")
+    }
+    if (matches.length === 0) throw editError("ANCHOR_NOT_FOUND", "anchors did not select a range")
+    if (matches.length !== 1) {
+      throw editError("ANCHOR_NOT_UNIQUE", `anchors selected ${matches.length} ranges, expected 1`)
+    }
+
+    const match = matches[0]
+    return {
+      changes: [
+        {
+          filePath,
+          oldContent: source.text,
+          newContent:
+            source.text.slice(0, match.start) + convertToLineEnding(params.new, ending) + source.text.slice(match.end),
+          bom: source.bom,
+          kind: "update",
+        },
+      ],
+    } satisfies EditPlan
+  })
+
+export const ReplaceByAnchorTool = Tool.define(
+  "replace_by_anchor",
+  Effect.gen(function* () {
+    const services = yield* captureEditToolkitServices
+    return {
+      description: DESCRIPTION,
+      parameters: Parameters,
+      execute: (params: Schema.Schema.Type<typeof Parameters>, ctx: Tool.Context) =>
+        Effect.gen(function* () {
+          const plan = yield* planReplaceByAnchor(services, ctx, params)
+          return yield* commitFileChanges(services, { tool: "replace_by_anchor", ctx, ...plan })
+        }).pipe(Effect.orDie),
+    }
+  }),
+)
+
+function findAnchorRanges(
+  content: string,
+  startAnchor: string,
+  endAnchor: string,
+  options: { includeStart: boolean; includeEnd: boolean; maxTargetLines: number },
+) {
+  const ranges: Array<{ start: number; end: number }> = []
+  let cursor = 0
+  while (cursor <= content.length) {
+    const startIndex = content.indexOf(startAnchor, cursor)
+    if (startIndex === -1) break
+    const endIndex = content.indexOf(endAnchor, startIndex + startAnchor.length)
+    if (endIndex === -1) break
+    const start = options.includeStart ? startIndex : startIndex + startAnchor.length
+    const end = options.includeEnd ? endIndex + endAnchor.length : endIndex
+    const targetLines = content.slice(start, end).split("\n").length
+    if (targetLines > options.maxTargetLines) {
+      throw editError("MAX_CHANGE_LIMIT_EXCEEDED", `anchor range has ${targetLines} lines`)
+    }
+    ranges.push({ start, end })
+    cursor = startIndex + startAnchor.length
+  }
+  return ranges
+}
diff --git a/packages/opencode/src/tool/replace_by_anchor.txt b/packages/opencode/src/tool/replace_by_anchor.txt
new file mode 100644
index 0000000..04e6382
--- /dev/null
+++ b/packages/opencode/src/tool/replace_by_anchor.txt
@@ -0,0 +1,13 @@
+Replace a text range selected by literal `start_anchor` and `end_anchor` strings. The anchors must select exactly one range (no regex, no semantic guessing); the tool fails if zero or more than one range matches. More robust than replace_exact when the inner text drifts but the surrounding markers are stable. The range may not exceed `max_target_lines` (default 200).
+
+Example: replace a function body, keeping the braces.
+{
+  "file": "src/auth.ts",
+  "start_anchor": "function login() {",
+  "end_anchor": "}",
+  "include_start": true,
+  "include_end": true,
+  "new": "function login() {\n  return createSession()\n}"
+}
+
+This tool only ever edits a single range, so `expected_matches` must be 1.
diff --git a/packages/opencode/src/tool/replace_exact.ts b/packages/opencode/src/tool/replace_exact.ts
new file mode 100644
index 0000000..825aa1f
--- /dev/null
+++ b/packages/opencode/src/tool/replace_exact.ts
@@ -0,0 +1,93 @@
+import { Effect, Schema } from "effect"
+import { InstanceState } from "@/effect/instance-state"
+import * as Tool from "./tool"
+import DESCRIPTION from "./replace_exact.txt"
+import {
+  assertEditableFile,
+  captureEditToolkitServices,
+  commitFileChanges,
+  convertToLineEnding,
+  countOccurrences,
+  detectLineEnding,
+  editError,
+  resolveToolFile,
+  verifySha256,
+  type EditPlan,
+  type EditToolkitServices,
+} from "./edit_toolkit"
+import type { Context } from "./tool"
+
+export const Parameters = Schema.Struct({
+  file: Schema.String.annotate({ description: "The file to edit. Absolute paths are accepted; relative paths resolve in the workspace." }),
+  expected_sha256: Schema.optional(Schema.String).annotate({
+    description: "Optional sha256 of the current file bytes. If provided, the edit is rejected when it does not match.",
+  }),
+  old: Schema.String.annotate({ description: "Exact text to replace." }),
+  new: Schema.String.annotate({ description: "Replacement text." }),
+  expected_occurrences: Schema.optional(Schema.Number).annotate({
+    description: "How many times old must occur. Defaults to 1.",
+  }),
+  replace_all: Schema.optional(Schema.Boolean).annotate({
+    description: "Replace all expected occurrences. Defaults to false; when false expected_occurrences must be 1.",
+  }),
+})
+
+export const planReplaceExact = (
+  services: EditToolkitServices,
+  ctx: Context,
+  params: Schema.Schema.Type<typeof Parameters>,
+) =>
+  Effect.gen(function* () {
+    if (params.old === params.new) throw editError("NO_CHANGES", "old and new are identical")
+    if (params.old === "") throw editError("OLD_TEXT_EMPTY", "old must not be empty")
+    const instance = yield* InstanceState.context
+    const filePath = resolveToolFile(instance, params.file)
+    const source = yield* assertEditableFile(ctx, services.fs, filePath)
+    yield* verifySha256(services.fs, filePath, params.expected_sha256)
+
+    const ending = detectLineEnding(source.text)
+    const oldText = convertToLineEnding(params.old, ending)
+    const newText = convertToLineEnding(params.new, ending)
+    const expected = params.expected_occurrences ?? 1
+    const occurrences = countOccurrences(source.text, oldText)
+    if (occurrences === 0) throw editError("OLD_TEXT_NOT_FOUND", `old text was not found in ${filePath}`)
+    if (occurrences !== expected) {
+      throw editError(
+        occurrences > 1 ? "AMBIGUOUS_MATCH" : "OCCURRENCE_MISMATCH",
+        `old text occurred ${occurrences} times in ${filePath}, expected ${expected}`,
+      )
+    }
+    if (!params.replace_all && expected !== 1) {
+      throw editError("AMBIGUOUS_MATCH", "replace_all must be true when expected_occurrences is greater than 1")
+    }
+
+    return {
+      changes: [
+        {
+          filePath,
+          oldContent: source.text,
+          newContent: params.replace_all
+            ? source.text.replaceAll(oldText, newText)
+            : source.text.replace(oldText, newText),
+          bom: source.bom,
+          kind: "update",
+        },
+      ],
+    } satisfies EditPlan
+  })
+
+export const ReplaceExactTool = Tool.define(
+  "replace_exact",
+  Effect.gen(function* () {
+    const services = yield* captureEditToolkitServices
+    return {
+      description: DESCRIPTION,
+      parameters: Parameters,
+      execute: (params: Schema.Schema.Type<typeof Parameters>, ctx: Tool.Context) =>
+        Effect.gen(function* () {
+          const plan = yield* planReplaceExact(services, ctx, params)
+          return yield* commitFileChanges(services, { tool: "replace_exact", ctx, ...plan })
+        }).pipe(Effect.orDie),
+    }
+  }),
+)
diff --git a/packages/opencode/src/tool/replace_exact.txt b/packages/opencode/src/tool/replace_exact.txt
new file mode 100644
index 0000000..915b65b
--- /dev/null
+++ b/packages/opencode/src/tool/replace_exact.txt
@@ -0,0 +1,11 @@
+Replace an exact text block in a file. The `old` text must occur exactly the requested number of times (default 1); the tool refuses ambiguous matches instead of guessing. Best for small, surgical edits (one branch, a couple of imports, a test assertion). Read the file first so `old` matches byte-for-byte.
+
+Example: change a return into a throw.
+{
+  "file": "src/auth.ts",
+  "old": "if (!user) return null",
+  "new": "if (!user) throw new AuthError('User not found')",
+  "expected_occurrences": 1
+}
+
+To replace several identical occurrences, set `expected_occurrences` to the exact count and `replace_all` to true. Pass `expected_sha256` (sha256 of the current file bytes) to reject the edit if the file changed since you read it.
